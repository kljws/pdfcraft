{
	"name": "pdfcraft",
	"version": "0.4.4",
	"description": "Modern PDF document generation for Node.js and browsers, written in TypeScript",
	"type": "module",
	"sideEffects": false,
	"packageManager": "npm@12.0.1",
	"author": "kljws",
	"license": "MIT",
	"homepage": "https://github.com/kljws/pdfcraft#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kljws/pdfcraft.git"
	},
	"bugs": {
		"url": "https://github.com/kljws/pdfcraft/issues"
	},
	"keywords": [
		"pdf",
		"javascript",
		"printing",
		"layout"
	],
	"main": "dist/index.cjs",
	"module": "dist/index.mjs",
	"types": "dist/index.d.mts",
	"engines": {
		"node": ">=22"
	},
	"files": [
		"dist",
		"CHANGELOG.md",
		"LICENSE",
		"README.md"
	],
	"dependencies": {
		"linebreak": "^1.1.0",
		"pdfkit": "^0.19.1",
		"svg-to-pdfkit": "0.1.8",
		"xmldoc": "^3.0.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^26.1.1",
		"@types/svg-to-pdfkit": "0.1.4",
		"@vitejs/plugin-react": "^6.0.3",
		"@vitest/browser-playwright": "^4.1.10",
		"@vitest/coverage-v8": "^4.1.10",
		"eslint": "^10.7.0",
		"globals": "^17.7.0",
		"pdfjs-dist": "^6.1.200",
		"playwright": "^1.61.1",
		"prettier": "^3.9.5",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"tsdown": "^0.22.9",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.64.0",
		"vite": "^8.1.5",
		"vitest": "^4.1.10"
	},
	"scripts": {
		"test": "npm run build && npm run test:types && npm run test:consumer && npm run test:unit && npm run test:integration && npm run test:browser && npm run lint && npm run format:check",
		"typecheck": "tsc --noEmit",
		"typecheck:build": "tsc --noEmit -p tsconfig.build.json",
		"build": "npm run typecheck:build && tsdown",
		"benchmark": "npm run build && node benchmarks/run.mjs",
		"benchmark:quick": "npm run build && node benchmarks/run.mjs --quick",
		"analyze:dependencies": "node scripts/analyze-dependency-weight.mjs",
		"check:size": "node scripts/check-package-size.mjs",
		"lint": "eslint \"./src/**/*.ts\" \"./tests/**/*.{ts,cts}\" \"./benchmarks/**/*.mjs\" \"./examples/**/*.js\" \"./playground/**/*.{js,jsx}\" \"./*.config.mts\"",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test:types": "tsc -p tests/types/tsconfig.node.json && tsc -p tests/types/tsconfig.browser.json",
		"test:consumer": "vitest run tests/consumer",
		"test:unit": "vitest run src",
		"test:integration": "vitest run tests/integration",
		"test:coverage": "vitest run src tests/integration --coverage",
		"test:browser": "vitest run --config vitest-browser.config.mts",
		"test:watch": "vitest",
		"prepack": "npm run build && npm run test:types && npm run test:consumer && npm run check:size",
		"playground": "npm run playground:react",
		"playground:server": "npm run build && node playground/server/server.js",
		"playground:react": "npm run build && vite --config playground/react/vite.config.js"
	},
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			},
			"default": "./dist/index.mjs"
		},
		"./browser": {
			"types": "./dist/browser.d.ts",
			"default": "./dist/browser.js"
		},
		"./types": {
			"types": "./dist/types.d.ts"
		},
		"./package.json": "./package.json"
	}
}
